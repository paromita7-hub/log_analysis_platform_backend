NODE_ENV=development
PORT=3000
LOG_LEVEL=info
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=iam-service-group
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://logpulse:logpulse@localhost:5432/logpulse
JWT_ACCESS_SECRET=replace-with-a-64-character-minimum-secret-value-for-development
JWT_REFRESH_SECRET=replace-with-a-second-64-character-minimum-secret-value-for-development
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12
